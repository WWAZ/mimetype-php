{
  "name": "wwaz/mimetype-php",
  "version": "0.1.0",
  "description": "Determines mimetype of a filepath (string) or file resource",
  "type": "library",
  "authors": [
    {
      "name": "WWAZ",
      "homepage": "https://github.com/WWAZ/"
    }
  ],
  "config": {
    "platform": {
      "php": "8.2"
    }
  },
  "autoload": {
    "psr-4": {
      "wwaz\\Mimetype\\": "src/"
    }
  },

  "license": "MIT",
  "require-dev": {
    "phpunit/phpunit": "^11"
  },
  "scripts": {
    "test": [
      "./vendor/bin/phpunit --colors=always tests"
    ]
  },
  "require": {
    "ralouphie/mimey": "^1.0"
  }
}
